# Development and docs
/dev/
/Dashboard/
*.code-workspace
.vscode/
.idea/
.DS_Store
*.log
*.map
*.zip
*.tar.gz

# Node artifacts (if any)
node_modules/

# Esbuild/TS caches
*.tsbuildinfo
.tsbuildinfo
.esbuild/
.cache/
cache/
tmp/
temp/

# Local build outputs that should not be versioned
# Keep built dashboard assets tracked (needed on remote sites)
!assets/js/dashboard/
!assets/js/dashboard/dashboard.js
!assets/js/dashboard/dashboard.css
assets/js/dashboard/*.map
dist/
build/
coverage/

# OS junk
Thumbs.db

# Shell/batch helpers not needed in release
*.sh
*.bat

# PHP/Composer and tests – exclude composer setup and vendor from pushes
composer.json
composer.lock
composer.phar
vendor/
phpunit.xml*
/.phpunit.result.cache
/tests/

# CI/config we don’t ship in release packages
.github/
!.github/
!.github/workflows/
!.github/workflows/*.yml
!.github/workflows/*.yaml
.gitea/
.gitlab/
key.b64
