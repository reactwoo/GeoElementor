{
    "name": "reactwoo/elementor-geo-popup",
    "description": "Trigger Elementor Pro Popups based on visitor IP/country using MaxMind GeoLite2",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "ReactWoo",
            "email": "info@reactwoo.com",
            "homepage": "https://reactwoo.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "geoip2/geoip2": "^2.0",
        "maxmind-db/reader": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "squizlabs/php_codesniffer": "^3.0",
        "phpcompatibility/php-compatibility": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "EGP\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EGP\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpcs": "phpcs --standard=WordPress",
        "phpcbf": "phpcbf --standard=WordPress"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}


